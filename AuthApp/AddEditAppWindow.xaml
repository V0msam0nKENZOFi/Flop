<Window x:Class="AuthApp.AddEditAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить/редактировать программу" Height="480" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Margin="20">
        <StackPanel Margin="25">
            <TextBlock Text="Программа" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Название" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
            <TextBox x:Name="NameBox" Margin="0,0,0,10" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>

            <TextBlock Text="Прямая ссылка на файл (URL)" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
            <TextBox x:Name="UrlBox" Margin="0,0,0,10" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>

            <TextBlock Text="Ссылка на иконку (URL, любой формат)" Foreground="{DynamicResource TextBrush}" Margin="0,10,0,5"/>
            <TextBox x:Name="IconUrlBox" Margin="0,0,0,10" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Сохранить" Width="100" Margin="0,0,10,0" Click="Save_Click"/>
                <Button Content="Отмена" Width="100" Click="Cancel_Click" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>
            <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>