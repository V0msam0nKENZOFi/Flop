<Window x:Class="AuthApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Главная" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid x:Name="MainContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Button x:Name="MenuButton" Content="☰" Width="40" Height="40" FontSize="20" Padding="0" Click="MenuButton_Click"/>
                    <TextBlock Text="AuthApp" FontSize="18" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
        </Grid>

        <Border x:Name="Overlay" Background="{DynamicResource OverlayBrush}" Visibility="Collapsed" Panel.ZIndex="100">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseMenuCommand}" />
            </Border.InputBindings>
        </Border>

        <Border x:Name="SideMenu" Width="260" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                HorizontalAlignment="Left" Visibility="Collapsed" Panel.ZIndex="101">
            <StackPanel>
                <Border Height="50" Background="{DynamicResource PrimaryBrush}">
                    <TextBlock Text="МЕНЮ" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="20,0" FontWeight="Bold"/>
                </Border>
                <ListBox x:Name="MenuListBox" Background="Transparent" BorderThickness="0" SelectedValuePath="Tag">
                    <ListBoxItem Tag="Home">Главная</ListBoxItem>
                    <ListBoxItem Tag="Settings">Настройки</ListBoxItem>
                    <ListBoxItem x:Name="UserManagementItem" Tag="UserManagement" Visibility="Collapsed">Управление пользователями</ListBoxItem>
                    <ListBoxItem Tag="Downloads">Приложения</ListBoxItem>
                    <Separator Margin="0,10" Background="{DynamicResource BorderBrush}"/>
                    <ListBoxItem Tag="Logout">Выйти</ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>
    </Grid>
</Window>