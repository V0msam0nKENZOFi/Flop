<Window x:Class="AuthApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="430" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize">
    <Grid>
        <Border Width="360" Height="280" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Margin="30,20">
                <TextBlock Text="Вход в систему" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                <TextBlock Text="Логин" Foreground="{DynamicResource TextBrush}"/>
                <TextBox x:Name="LoginBox" Margin="0,5,0,15"/>
                <TextBlock Text="Пароль" Foreground="{DynamicResource TextBrush}"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,5,0,20"/>
                <Button Content="Войти" Click="Login_Click" Height="40" FontSize="16"/>
                <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>