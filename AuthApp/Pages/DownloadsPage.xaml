<Page x:Class="AuthApp.Pages.DownloadsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:AuthApp.Pages"
      Background="{DynamicResource BackgroundBrush}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ImageConverter x:Key="ImageConverter"/>
        <local:StringNotEmptyConverter x:Key="StringNotEmpty"/>
    </Page.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Приложения" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" x:Name="AdminPanel" Visibility="Collapsed">
            <Button Content="➕ Добавить приложение" Click="AddApp_Click" Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="🔄 Обновить список" Click="RefreshApps_Click" Padding="10,5"/>
        </StackPanel>

        <!-- Красивый поиск по центру -->
        <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,15">
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="20" Padding="6,2" Width="350">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16" Margin="6,0,4,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchBox" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             Foreground="{DynamicResource TextBrush}"
                             FontSize="14"
                             TextChanged="SearchBox_TextChanged"
                             Width="290"
                             VerticalAlignment="Center"
                             CaretBrush="{DynamicResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
            <!-- Водяной знак (placeholder) по центру -->
            <TextBlock Text="Поиск приложений..." 
                       Foreground="{DynamicResource TextSecondaryBrush}" 
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringNotEmpty}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <ListBox Grid.Row="3" x:Name="AppsListBox" 
                 Background="Transparent" 
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Margin="8,0,8,8" Padding="8,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            Width="300" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.RowSpan="2" Grid.Column="0" Width="64" Height="64" Margin="0,0,16,0">
                                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="32"/>
                                <Image Source="{Binding IconPath, Converter={StaticResource ImageConverter}}" 
                                       Stretch="Uniform" 
                                       Width="48" Height="48"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,4"/>

                            <Button Grid.Row="1" Grid.Column="1" Content="📥 Скачать" Margin="0,0,8,0" Padding="8,4" Click="DownloadApp_Click" Tag="{Binding Id}" 
                                    Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontSize="13" HorizontalAlignment="Left"/>

                            <StackPanel Grid.RowSpan="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" 
                                        Visibility="{Binding DataContext.IsCreator, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVis}}">
                                <Button Content="✏️" Width="40" Margin="6,0" Padding="0" Click="EditApp_Click" Tag="{Binding Id}"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontSize="16"/>
                                <Button Content="🗑️" Width="40" Margin="6,0" Padding="0" Click="DeleteApp_Click" Tag="{Binding Id}"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontSize="16"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</Page>