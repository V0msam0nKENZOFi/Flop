<Page x:Class="AuthApp.Pages.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление пользователями" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,20"/>

        <!-- Форма добавления -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Добавить нового пользователя" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewLoginBox" Grid.Column="0" Margin="0,0,10,0" Tag="Логин" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    <PasswordBox x:Name="NewPasswordBox" Grid.Column="1" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    <ComboBox x:Name="RoleCombo" Grid.Column="2" Width="100" Margin="0,0,10,0" SelectedIndex="0"
                              Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    <Button Content="Создать" Grid.Column="3" Click="CreateUser_Click" Width="100"/>
                </Grid>
                <TextBlock x:Name="CreateErrorText" Foreground="Red" Margin="0,5,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Список пользователей -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="15" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Существующие пользователи" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox x:Name="UsersListBox" Height="300" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Login}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                    <Button Grid.Column="2" Content="Редактировать" Width="90" Margin="5,0" Click="EditUser_Click" Tag="{Binding Login}"/>
                                    <Button Grid.Column="3" Content="Удалить" Width="70" Click="DeleteUser_Click" Tag="{Binding Login}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </Grid>
</Page>