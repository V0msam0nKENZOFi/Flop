<Page x:Class="AuthApp.Pages.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20" Width="550">
            <!-- Заголовок -->
            <TextBlock Text="Управление пользователями" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Блок добавления нового пользователя (компактный) -->
            <Border Background="{DynamicResource SurfaceBrush}" Padding="15" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Добавить нового пользователя" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewLoginBox" Grid.Column="0" Margin="0,0,8,0" Height="30" 
                                 Foreground="{DynamicResource TextBrush}" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" Tag="Логин"/>
                        <PasswordBox x:Name="NewPasswordBox" Grid.Column="1" Margin="0,0,8,0" Height="30"
                                     Foreground="{DynamicResource TextBrush}" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                        <ComboBox x:Name="RoleCombo" Grid.Column="2" Width="90" Margin="0,0,8,0" Height="30" SelectedIndex="0"
                                  Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Content="➕ Создать" Grid.Column="3" Click="CreateUser_Click" Width="90" Height="30" Padding="0"/>
                    </Grid>
                    <TextBlock x:Name="CreateErrorText" Foreground="Red" Margin="0,8,0,0" Visibility="Collapsed" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Блок существующих пользователей (компактный) -->
            <Border Background="{DynamicResource SurfaceBrush}" Padding="15" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Существующие пользователи" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                    <ListBox x:Name="UsersListBox" Height="280" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Login}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" FontSize="13"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <Button Grid.Column="2" Content="✏️ Редактировать" Width="90" Margin="4,0" Click="EditUser_Click" Tag="{Binding Login}" 
                                                Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" FontSize="11"/>
                                        <Button Grid.Column="3" Content="🗑️" Width="50" Margin="4,0" Click="DeleteUser_Click" Tag="{Binding Login}"
                                                Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>